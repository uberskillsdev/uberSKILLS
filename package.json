{
  "name": "uberskills",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/uberskills/uberskills.git"
  },
  "homepage": "https://github.com/uberskills/uberskills",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "db:migrate": "turbo run db:migrate"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@vitest/coverage-v8": "^4.0.18",
    "turbo": "^2",
    "typescript": "^5.7",
    "vitest": "^4.0.18"
  },
  "packageManager": "bun@1.3.10"
}
