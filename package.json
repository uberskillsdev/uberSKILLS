{
  "name": "@uberskillsdev/uberskills",
  "private": false,
  "bin": {
    "uberskills": "./bin/uberskills.mjs"
  },
  "files": [
    "bin/"
  ],
  "license": "MIT",
  "author": "Helder Vasconcelos",
  "version": "0.9.5",
  "email": "heldervasc@bearstouch.com",
  "url": "https://github.com/uberskillsdev",
  "repository": {
    "type": "git",
    "url": "https://github.com/uberskillsdev/uberskills.git"
  },
  "homepage": "https://github.com/uberskillsdev/uberskills",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@uberskills/web",
    "dev:landing": "turbo run dev --filter=@uberskills/landing",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "db:migrate": "turbo run db:migrate",
    "db:reset": "turbo run db:reset",
    "start": "turbo run start"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.19.0",
    "turbo": "^2",
    "typescript": "^5.7",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@9.15.4",
  "dependencies": {
    "ora": "^9.3.0"
  }
}
