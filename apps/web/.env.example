# UberSkills Environment Variables
# Copy this file to .env.local and modify as needed.
# Do NOT commit .env.local to version control.

# Database connection string.
# Use "file:" prefix for local SQLite (default) or "libsql://" for Turso.
DATABASE_URL=file:data/uberskills.db

# AES-256-GCM encryption key for securing the OpenRouter API key at rest.
# If not set, a key is auto-generated at data/.secret on first run.
# ENCRYPTION_SECRET=

# Web server port.
PORT=3000

# Environment mode (development | production).
NODE_ENV=development
