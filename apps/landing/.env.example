# uberSKILLS Landing Page — Environment Variables
# Copy this file to .env.local and modify as needed.
# Do NOT commit .env.local to version control.

# URL to the editor app. Used for cross-app links (e.g. "Open Dashboard").
# In production, set this to the editor app's URL.
# Defaults to "/" if not set.
NEXT_PUBLIC_EDITOR_URL=/

# Environment mode (development | production).
NODE_ENV=development
